Subject: Get started with LaxHornet
MIME-Version: 1.0
Content-Type: text/html; charset=UTF-8

<!doctype html>
<html lang="en">
  <body style="margin:0; padding:0; background:#f1f2f4; color:#111317; font-family:Arial, Helvetica, sans-serif;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f1f2f4; margin:0; padding:24px 12px;">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width:640px; background:#ffffff; border-collapse:collapse; border-radius:8px; overflow:hidden;">
            <tr>
              <td style="background:#111111; padding:28px 26px 24px; color:#ffffff;">
                <img src="https://mybranford.com/assets/laxhornet-logo.png" alt="LaxHornet" width="280" style="display:block; max-width:100%; height:auto; margin:0 0 20px;" />
                <h1 style="margin:0; color:#ffffff; font-size:30px; line-height:1.08; font-weight:800;">Fast stats for a fast game.</h1>
                <p style="margin:12px 0 0; color:#d8dadd; font-size:16px; line-height:1.5;">LaxHornet lets parents track youth lacrosse stats by verified player, review season totals, and share live game updates from another phone, tablet, or computer.</p>
              </td>
            </tr>
            <tr>
              <td style="padding:26px;">
                <p style="margin:0 0 16px; color:#30343a; font-size:16px; line-height:1.5;">We are using <strong>LaxHornet</strong> to help track lacrosse stats during the season. Each parent account can request access to a team and verify their child by jersey number.</p>
                <p style="margin:22px 0;"><a href="https://mybranford.com/" style="display:inline-block; padding:14px 20px; border-radius:8px; background:#e81010; color:#ffffff; font-size:16px; font-weight:800; text-decoration:none;">Open LaxHornet</a></p>
                <p style="margin:0 0 18px; color:#555d67; font-size:14px; line-height:1.5;">Direct link: <a href="https://mybranford.com/" style="color:#e81010; font-weight:700;">https://mybranford.com/</a></p>
                <p><a href="https://mybranford.com/"><img src="https://mybranford.com/launch-kit/laxhornet-qr.png" alt="QR code for LaxHornet" width="150" style="display:block; width:150px; height:auto; border:1px solid #d8dadd; border-radius:8px; padding:8px; background:#ffffff;" /></a></p>
                <h2 style="margin:20px 0 10px; color:#111317; font-size:20px; line-height:1.2;">Parent Setup</h2>
                <ol style="margin:0; padding-left:20px; color:#30343a; font-size:15px; line-height:1.45;">
                  <li>Create an account with your email and password.</li>
                  <li>Enter your first name, last name, team code, and child jersey number.</li>
                  <li>After approval, sign back in.</li>
                  <li>Choose your verified player/team tile and track games.</li>
                </ol>
                <p style="margin-top:22px; padding:16px; border-left:5px solid #e81010; background:#f1f2f4; border-radius:8px; color:#30343a; font-size:15px; line-height:1.5;"><strong>Team code:</strong> ____________________<br /><strong>Child jersey number:</strong> enter the number your child wears for this team.</p>
                <p style="margin-top:20px; color:#555d67; font-size:14px; line-height:1.5;">On iPhone, open the link in Safari, tap Share, tap Add to Home Screen, then open LaxHornet from the new icon.</p>
              </td>
            </tr>
            <tr>
              <td style="padding:18px 26px; background:#111111; color:#c6c8cc; font-size:12px; line-height:1.4;">LaxHornet Youth Lacrosse Stat Tracker<br /><a href="https://mybranford.com/" style="color:#ffffff;">Open the app</a></td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
